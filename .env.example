# ─────────────────────────────────────────────────────────────────────────────
# Astro Consultancy — environment variables
# Copy to .env.local and fill in. .env.local is gitignored; this file is committed.
# Everything is optional for the scaffold to RUN (clients are stubbed when blank),
# but real functionality requires the relevant values.
# ─────────────────────────────────────────────────────────────────────────────

# Postgres (Neon). Pooled connection string used by the Neon serverless driver.
DATABASE_URL=

# Auth.js (NextAuth v5)
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=
# Base URL of the app. Dev: http://localhost:3001 — Prod: https://astro.hifiai.in
AUTH_URL=
# Google OAuth credentials (one client, two uses — sign-in AND Calendar; no separate secret).
# Sign-in redirect URI:  http://localhost:3001/api/auth/callback/google  (prod: https://astro.hifiai.in/...)
# Track I T-1.1 Google Calendar connect uses the SAME client with a DISTINCT redirect URI + extra scopes.
#   Add these AUTHORIZED REDIRECT URIs in Google Cloud Console → Credentials → the OAuth client:
#     dev:  http://localhost:3001/api/calendar/callback
#     prod: https://astro.hifiai.in/api/calendar/callback
#   Add these SCOPES on the OAuth consent screen:
#     https://www.googleapis.com/auth/calendar.events
#     https://www.googleapis.com/auth/calendar.readonly
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (Resend) — send from a verified domain; empty key falls back to console/terminal in dev
RESEND_API_KEY=
EMAIL_FROM="Astro Consultancy <bookings@mail.hifiai.in>"

# AI content assistant (Google Gemini). Key: https://aistudio.google.com/app/apikeys — empty = AI buttons hidden
GOOGLE_AI_STUDIO_API_KEY=

# Storage (Cloudflare R2, S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Error monitoring (Sentry). App is fully inert when these are empty.
SENTRY_DSN=
# Optional: client-side DSN (inlined into the browser bundle).
NEXT_PUBLIC_SENTRY_DSN=

# Application-level encryption key (e.g. for encrypting consultant payment credentials).
# Generate with: openssl rand -base64 32
ENCRYPTION_MASTER_KEY=

# Our subscription billing (platform revenue). Mock gateway in Phase 1.
# Shared secret used to sign/verify billing webhooks (HMAC-SHA256). Required to accept webhooks.
BILLING_WEBHOOK_SECRET=
# Shared secret the dunning cron must send (x-cron-secret header) to /api/cron/billing-dunning.
BILLING_CRON_SECRET=
# Our GST identity, printed on subscription receipts.
PLATFORM_GST_NUMBER=
PLATFORM_LEGAL_NAME=

# Platform operator (super-admin) email. Seeded as the super_admin user + receives lead/admin notifications.
# Dev: defaults to admin@astro.local when blank. PROD: REQUIRED — a real address; the dev placeholder is
# rejected in production (resolveSuperadminEmail throws), which would break seeding + notifications.
SUPERADMIN_EMAIL=
