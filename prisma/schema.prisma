// Prisma schema — foundation only (NOT the full product schema).
// Stack: Postgres (Neon) + Prisma 7 driver adapters (Neon serverless driver).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Row-Level Security (RLS) — deferred, documented for later ────────────────
// Tenant = organization. Tenant-scoped tables carry an org reference and will be
// guarded by Postgres RLS in a later phase, e.g.:
//   USING (org_id = current_org())  with a super_admin bypass policy.
// In Phase 1, tenant isolation is enforced at the application / query layer.
// `users` is global (operators, seekers, consultants); the only tenant-scoped
// table so far is `org_members` (via organizationId). Grow RLS coverage as more
// tenant-scoped tables (packages, bookings, …) are added in later sub-phases.

// ─── Tenancy ────────────────────────────────────────────────────────────────

enum UserRole {
  super_admin
  consultant
  team_consulting
  team_accounts
  seeker
}

enum MemberRole {
  consultant
  team_consulting
  team_accounts
}

enum OrgStatus {
  active
  suspended
}

enum MemberStatus {
  active
  invited
  removed
}

model User {
  id            String      @id @default(cuid())
  role          UserRole    @default(seeker)
  name          String?
  // Unique + normalized to lowercase at write time (see lib/* / seed).
  // `citext` is a future option if DB-level case-insensitivity is preferred.
  email         String?     @unique
  phone         String?
  authProvider  String?
  passwordHash  String?
  emailVerified DateTime?   @db.Timestamptz(6)
  image         String?
  createdAt     DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime    @updatedAt @db.Timestamptz(6)

  accounts           Account[]
  sessions           Session[]
  memberships        OrgMember[]
  ownedOrganizations Organization[] @relation("OrgOwner")

  @@map("users")
}

model Organization {
  id          String      @id @default(cuid())
  ownerUserId String?
  name        String
  // Unique + normalized to lowercase at write time. `citext` is a future option.
  slug        String      @unique
  status      OrgStatus   @default(active)
  createdAt   DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime    @updatedAt @db.Timestamptz(6)

  owner   User?       @relation("OrgOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  members OrgMember[]

  @@map("organizations")
}

model OrgMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           MemberRole   @default(consultant)
  status         MemberStatus @default(active)
  // Drives per-seat billing: count active billable seats per org.
  isBillableSeat Boolean      @default(true)
  createdAt      DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime     @updatedAt @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId, role, status])
  @@map("org_members")
}

// ─── Auth.js (NextAuth) models ───────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime @db.Timestamptz(6)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime @db.Timestamptz(6)

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Email + OTP (one-time codes) ────────────────────────────────────────────

model VerificationCode {
  id           String   @id @default(cuid())
  email        String
  // SHA-256 hash of the 6-digit code — the plaintext is never stored.
  codeHash     String
  expiresAt    DateTime @db.Timestamptz(6)
  consumed     Boolean  @default(false)
  // Verify attempts against this code; locked once it exceeds the cap.
  attemptCount Int      @default(0)
  // Issuing client IP, for per-IP issuance rate limiting.
  requestIp    String?
  createdAt    DateTime @default(now()) @db.Timestamptz(6)

  @@index([email, createdAt])
  @@map("verification_codes")
}

// ─── Audit log ────────────────────────────────────────────────────────────────
// Append-only record of privileged mutations (org create/update/suspend/reactivate, …).
// Cross-tenant by design (written by privileged paths, read by the super admin); NOT scoped
// via tenantDb. No FK on actorUserId so history is retained even if a user is removed.

model AuditLog {
  id           String   @id @default(cuid())
  actorUserId  String?
  action       String
  resourceType String
  resourceId   String?
  orgId        String?
  metadata     Json?
  createdAt    DateTime @default(now()) @db.Timestamptz(6)

  @@index([orgId, createdAt])
  @@index([resourceType, resourceId])
  @@map("audit_logs")
}
