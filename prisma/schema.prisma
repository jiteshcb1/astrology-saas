// Prisma schema — foundation only (NOT the full product schema).
// Stack: Postgres (Neon) + Prisma 7 driver adapters (Neon serverless driver).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Row-Level Security (RLS) — deferred, documented for later ────────────────
// Tenant = organization. Tenant-scoped tables carry an org reference and will be
// guarded by Postgres RLS in a later phase, e.g.:
//   USING (org_id = current_org())  with a super_admin bypass policy.
// In Phase 1, tenant isolation is enforced at the application / query layer.
// `users` is global (operators, seekers, consultants); the only tenant-scoped
// table so far is `org_members` (via organizationId). Grow RLS coverage as more
// tenant-scoped tables (packages, bookings, …) are added in later sub-phases.

// ─── Tenancy ────────────────────────────────────────────────────────────────

enum UserRole {
  super_admin
  consultant
  team_consulting
  team_accounts
  seeker
}

enum MemberRole {
  consultant
  team_consulting
  team_accounts
}

enum OrgStatus {
  active
  suspended
}

enum MemberStatus {
  active
  invited
  removed
}

model User {
  id            String      @id @default(cuid())
  role          UserRole    @default(seeker)
  name          String?
  // Unique + normalized to lowercase at write time (see lib/* / seed).
  // `citext` is a future option if DB-level case-insensitivity is preferred.
  email         String?     @unique
  phone         String?
  authProvider  String?
  passwordHash  String?
  emailVerified DateTime?   @db.Timestamptz(6)
  image         String?
  createdAt     DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime    @updatedAt @db.Timestamptz(6)

  accounts           Account[]
  sessions           Session[]
  memberships        OrgMember[]
  ownedOrganizations Organization[] @relation("OrgOwner")
  bookingsAsSeeker   Booking[]      @relation("SeekerBookings")

  @@map("users")
}

model Organization {
  id          String      @id @default(cuid())
  ownerUserId String?
  name        String
  // Unique + normalized to lowercase at write time. `citext` is a future option.
  slug        String      @unique
  status      OrgStatus   @default(active)
  createdAt   DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime    @updatedAt @db.Timestamptz(6)

  owner             User?              @relation("OrgOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  members           OrgMember[]
  subscription      Subscription?
  receipts          Receipt[]
  consultantProfile ConsultantProfile?
  branding          OrgBranding?
  legalDocuments    LegalDocuments?
  paymentMethod     PaymentMethod?
  schedules         AvailabilitySchedule[]
  packages          Package[]
  bookings          Booking[]

  @@map("organizations")
}

model OrgMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           MemberRole   @default(consultant)
  status         MemberStatus @default(active)
  // Drives per-seat billing: count active billable seats per org.
  isBillableSeat Boolean      @default(true)
  createdAt      DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime     @updatedAt @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId, role, status])
  @@map("org_members")
}

// ─── Auth.js (NextAuth) models ───────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime @db.Timestamptz(6)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime @db.Timestamptz(6)

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Email + OTP (one-time codes) ────────────────────────────────────────────

model VerificationCode {
  id           String   @id @default(cuid())
  email        String
  // SHA-256 hash of the 6-digit code — the plaintext is never stored.
  codeHash     String
  expiresAt    DateTime @db.Timestamptz(6)
  consumed     Boolean  @default(false)
  // Verify attempts against this code; locked once it exceeds the cap.
  attemptCount Int      @default(0)
  // Issuing client IP, for per-IP issuance rate limiting.
  requestIp    String?
  createdAt    DateTime @default(now()) @db.Timestamptz(6)

  @@index([email, createdAt])
  @@map("verification_codes")
}

// ─── Audit log ────────────────────────────────────────────────────────────────
// Append-only record of privileged mutations (org create/update/suspend/reactivate, …).
// Cross-tenant by design (written by privileged paths, read by the super admin); NOT scoped
// via tenantDb. No FK on actorUserId so history is retained even if a user is removed.

model AuditLog {
  id           String   @id @default(cuid())
  actorUserId  String?
  action       String
  resourceType String
  resourceId   String?
  orgId        String?
  metadata     Json?
  createdAt    DateTime @default(now()) @db.Timestamptz(6)

  @@index([orgId, createdAt])
  @@index([resourceType, resourceId])
  @@map("audit_logs")
}

// ─── Billing (our subscription revenue) ──────────────────────────────────────
// Platform-level (super-admin managed). Money is integer paise + explicit currency — never float.
// subscription_plans is global; subscriptions is 1:1 with an org but managed by the super admin
// + the SP-1.6 gateway/cron (no tenant-actor path), so it is NOT registered in tenantDb.

enum BillingInterval {
  monthly
  yearly
}

enum SubscriptionStatus {
  active
  past_due
  canceled
}

model SubscriptionPlan {
  id              String          @id @default(cuid())
  name            String
  price           Int // paise — base price, includes `includedSeats` seats
  currency        String          @default("INR")
  billingInterval BillingInterval @default(monthly)
  includedSeats   Int             @default(1)
  perSeatPrice    Int             @default(0) // paise per seat beyond includedSeats
  features        Json            @default("{}") // key→bool map (consumed by SP-1.5)
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime        @updatedAt @db.Timestamptz(6)

  subscriptions Subscription[]

  @@map("subscription_plans")
}

model Subscription {
  id                     String             @id @default(cuid())
  orgId                  String             @unique
  planId                 String
  seatCount              Int                @default(1)
  status                 SubscriptionStatus @default(active)
  currentPeriodEnd       DateTime?          @db.Timestamptz(6) // set by the gateway on charge
  gatewaySubscriptionRef String? // gateway's subscription id
  pastDueSince           DateTime?          @db.Timestamptz(6) // set on payment failure; grace clock
  // True only when WE suspended the org for non-payment — so recovery never un-suspends a
  // manually suspended org. Distinguishes billing suspension from a super-admin manual suspend.
  suspendedForNonpayment Boolean            @default(false)
  createdAt              DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt              DateTime           @updatedAt @db.Timestamptz(6)

  organization Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  plan         SubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([planId])
  @@index([status])
  @@map("subscriptions")
}

// ─── Feature flags (config-as-data) ──────────────────────────────────────────
// Platform-level (super-admin managed). Resolver precedence: org > plan > global > false.
// scopeId: null for global, planId for plan, orgId for org. NOT registered in tenantDb (no
// tenant-actor write path; the resolver reads via explicit scope/scopeId filters).

enum FlagScope {
  global
  plan
  org
}

model FeatureFlag {
  id        String    @id @default(cuid())
  key       String
  scope     FlagScope
  scopeId   String?
  enabled   Boolean   @default(false)
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)

  @@unique([key, scope, scopeId])
  @@index([scope, scopeId])
  @@map("feature_flags")
}

// ─── Billing receipts + webhook ledger ───────────────────────────────────────
// `receipts` is TENANT-SCOPED (read by the Accounts role in later phases) → registered in
// config/tenant-models.json + lib/tenant-db.ts. `billing_events` is the platform-level webhook
// dedup ledger (no tenant-actor path) → NOT registered, like subscriptions/feature_flags.
// All money is integer paise + explicit currency.

enum ReceiptType {
  consultation
  subscription
}

model Receipt {
  id            String      @id @default(cuid())
  organizationId String
  type          ReceiptType
  bookingId     String? // consultation receipts (SP-4); null for subscription
  issuedTo      String
  gstNumberUsed String?
  amount        Int // paise
  currency      String      @default("INR")
  pdfUrl        String?
  issuedAt      DateTime    @default(now()) @db.Timestamptz(6)
  createdAt     DateTime    @default(now()) @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, type])
  @@map("receipts")
}

model BillingEvent {
  id             String   @id @default(cuid())
  gatewayEventId String   @unique // dedup: a replay collides here and the apply tx rolls back
  type           String
  payload        Json?
  createdAt      DateTime @default(now()) @db.Timestamptz(6)

  @@map("billing_events")
}

// ─── Consultant profile (SP-2) — tenant-scoped (1:1 org) ─────────────────────
// Public bio data + onboarding state. Registered in config/tenant-models.json.

model ConsultantProfile {
  id                      String    @id @default(cuid())
  organizationId          String    @unique
  displayName             String?
  businessType            String?
  timezone                String    @default("Asia/Kolkata")
  bio                     String?
  experience              String?
  specialities            String[]
  socialLinks             Json      @default("{}")
  gstNumber               String?
  gstLegalName            String?
  complaintsContactNumber String?
  onboardedAt             DateTime? @db.Timestamptz(6)
  createdAt               DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt               DateTime  @updatedAt @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("consultant_profiles")
}

// ─── Consultant branding (SP-2.3) — tenant-scoped (1:1 org) ──────────────────
// Public booking-page personalization. themeColor/fontKey are constrained to the active
// theme_color/font catalogs at write time; logoKey is an R2 object key (resolved to a signed
// URL on read — storing a URL would rot). Registered in config/tenant-models.json.

model OrgBranding {
  id             String   @id @default(cuid())
  organizationId String   @unique
  logoKey         String?
  themeColor      String?
  fontKey         String?
  defaultLocale   String   @default("en")
  backgroundStyle String   @default("stars_zodiac") // none | stars | zodiac | stars_zodiac (profile hero)
  createdAt       DateTime @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("org_branding")
}

// Per-consultant legal docs (tenant-scoped, 1:1 org). Rich HTML, sanitized on save. updatedAt drives the
// "Last updated" date on the public profile. Registered in config/tenant-models.json.
model LegalDocuments {
  id              String   @id @default(cuid())
  organizationId  String   @unique
  privacyPolicy   String   @default("")
  termsConditions String   @default("")
  createdAt       DateTime @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("legal_documents")
}

// Platform-level legal docs (super-admin authored, NOT tenant-scoped). docType ∈ privacy | terms_of_use |
// terms. Viewable at /legal/*; the landing page links to them later. Accessed via bare prisma.platformLegal.
model PlatformLegal {
  id          String   @id @default(cuid())
  docType     String   @unique
  contentHtml String   @default("")
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @db.Timestamptz(6)

  @@map("platform_legal")
}

// Platform-level operational settings (super-admin gated, NOT tenant-scoped). Single source of truth for
// system-wide toggles keyed by string (e.g. emails.otp, emails.transactional). value is flexible Json
// ({enabled:boolean} for the email switches). Absent row = default ON. Accessed via bare prisma.platformSetting.
model PlatformSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json     @default("{}")
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@map("platform_settings")
}

// ─── Payment methods (SP-2.4) — tenant-scoped (1:1 org) ──────────────────────
// How the consultant collects money from seekers. The platform NEVER touches funds. Two modes:
// UPI QR (VPA + uploaded QR image) or BYO gateway (Razorpay manual keys). Gateway secrets are
// envelope-encrypted (lib/crypto.ts) — plaintext is never stored, returned, or logged. connectionType
// + oauthTokenEnc are reserved so OAuth slots in later with no schema break. Registered in
// config/tenant-models.json.

model PaymentMethod {
  id                  String   @id @default(cuid())
  organizationId      String   @unique
  mode                String // "upi_qr" | "gateway"
  upiVpa              String?
  qrImageKey          String? // R2 object key
  gatewayProvider     String? // "razorpay" (cashfree/phonepe later)
  connectionType      String   @default("manual_keys") // reserve "oauth"
  gatewayKeyIdEnc     String? // envelope-encrypted
  gatewayKeySecretEnc String? // envelope-encrypted
  gatewayKeyIdLast4   String? // non-secret masked hint for UI
  gatewayWebhookSecretEnc String? // envelope-encrypted Razorpay webhook secret (SP-4.3, optional)
  oauthTokenEnc       String? // reserved (null) — future OAuth
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime @updatedAt @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("payment_methods")
}

// ─── Scheduling engine (SP-3) — tenant-scoped ────────────────────────────────
// Availability schedules + weekly rules + date overrides; packages (event types) with per-package
// pricing + limits; bookings; and booking_slots which carries the HARD no-double-book invariant via a
// GiST exclusion constraint (added in a manual migration — see the booking_engine migration). All
// carry organizationId and are registered in config/tenant-models.json. Times are stored UTC
// (Timestamptz); availability start/end are local "HH:mm" clock strings in the schedule's timezone.

model AvailabilitySchedule {
  id             String   @id @default(cuid())
  organizationId String
  ownerMemberId  String?
  name           String
  timezone       String   @default("Asia/Kolkata")
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @db.Timestamptz(6)

  organization Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  rules        AvailabilityRule[]
  overrides    AvailabilityOverride[]
  packages     Package[]

  @@index([organizationId])
  @@map("availability_schedules")
}

model AvailabilityRule {
  id             String @id @default(cuid())
  organizationId String
  scheduleId     String
  weekday        Int // 0=Sun … 6=Sat
  startTime      String // "HH:mm" local clock time in the schedule's timezone
  endTime        String

  schedule AvailabilitySchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId])
  @@map("availability_rules")
}

model AvailabilityOverride {
  id             String   @id @default(cuid())
  organizationId String
  scheduleId     String
  date           DateTime @db.Date
  isUnavailable  Boolean  @default(true)
  startTime      String? // custom hours when not unavailable
  endTime        String?

  schedule AvailabilitySchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId])
  @@map("availability_overrides")
}

model Package {
  id                      String   @id @default(cuid())
  organizationId          String
  title                   String
  slug                    String
  description             String?
  allowedDurations        Int[] // minutes, e.g. [15,30,45,60]
  defaultDurationMin      Int      @default(30)
  allowBookerChooseDuration Boolean @default(false)
  price                   Int      @default(0) // paise
  currency                String   @default("INR")
  locationType            String   @default("google_meet")
  scheduleId              String?
  bufferBeforeMin         Int      @default(0)
  bufferAfterMin          Int      @default(0)
  minNoticeMin            Int      @default(0)
  slotIntervalMin         Int      @default(15)
  freqLimit               Json     @default("{}") // { per_day?, per_week?, per_month? }
  assignmentMode          String   @default("round_robin")
  isActive                Boolean  @default(true)
  createdAt               DateTime @default(now()) @db.Timestamptz(6)
  updatedAt               DateTime @updatedAt @db.Timestamptz(6)

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  schedule     AvailabilitySchedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  bookings     Booking[]
  questions    PackageQuestion[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("packages")
}

// Per-package intake questions shown on the public booking form (SP-4.2). Tenant-scoped; registered in
// config/tenant-models.json. fieldType ∈ short_text|long_text|select|date|email|phone; requirement ∈
// required|optional|hidden; options (Json string[]) used by select.
model PackageQuestion {
  id             String   @id @default(cuid())
  organizationId String
  packageId      String
  label          String
  fieldType      String   @default("short_text")
  requirement    String   @default("optional")
  options        Json     @default("[]")
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now()) @db.Timestamptz(6)

  package Package @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId])
  @@map("package_questions")
}

// status lifecycle: held → pending_payment (details captured) → [gateway] confirmed / [UPI]
// pending_verification → confirmed (consultant) | cancelled; or expired (sweep) / payment_failed.
// holdExpiresAt drives the hold window; the sweep + lazy expiry free held/pending_payment rows past it.
// pending_verification/confirmed/confirming are LIVE (block the slot) — see lib/scheduling.ts.
model Booking {
  id               String    @id @default(cuid())
  organizationId   String
  seekerUserId     String? // null for public (unauthenticated) bookings
  seekerName       String?
  seekerEmail      String?
  seekerPhone      String?
  packageId        String
  assignedMemberId String? // round-robin host (SP-5); single-host for now
  durationMin      Int
  status           String    @default("held")
  holdExpiresAt    DateTime? @db.Timestamptz(6)
  answers          Json      @default("{}")
  tosAcceptedAt    DateTime? @db.Timestamptz(6)
  rescheduleCount  Int       @default(0)
  meetLink         String?
  createdAt        DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  seeker       User?        @relation("SeekerBookings", fields: [seekerUserId], references: [id], onDelete: SetNull)
  package      Package      @relation(fields: [packageId], references: [id], onDelete: Cascade)
  slot         BookingSlot?
  payment      Payment?

  @@index([organizationId, status])
  @@map("bookings")
}

// booking_slots carries the no-double-book invariant. startsAt/endsAt are Prisma-managed so the row is
// inserted via the tenant facade; the EXCLUDE constraint (added in the booking_engine migration)
// operates on the expression tstzrange(starts_at, ends_at, '[)') WHERE (active). active=false releases
// a hold without losing history.
model BookingSlot {
  id             String   @id @default(cuid())
  organizationId String
  bookingId      String   @unique
  hostMemberId   String
  startsAt       DateTime @db.Timestamptz(6)
  endsAt         DateTime @db.Timestamptz(6)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @db.Timestamptz(6)

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([hostMemberId])
  @@map("booking_slots")
}

// Per-booking payment record (SP-4.3). Tenant-scoped (registered). The platform never touches funds:
// gateway = an order on the CONSULTANT's own Razorpay keys; upi_qr = the consultant's own VPA. amount in
// paise. gatewayPaymentRef @unique guards duplicate gateway confirms (nullable → many UPI rows allowed).
model Payment {
  id               String   @id @default(cuid())
  organizationId   String
  bookingId        String   @unique
  mode             String // upi_qr | gateway
  amount           Int // paise
  currency         String   @default("INR")
  status           String   @default("initiated") // initiated | pending_verification | success | failed | refunded
  proofImageKey    String? // R2 object key (UPI proof screenshot/PDF)
  utrReference     String? // seeker-entered UPI transaction reference
  gatewayOrderId   String?
  gatewayPaymentRef String?  @unique
  verifiedByUserId String? // consultant/team member who confirmed a UPI proof
  createdAt        DateTime @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @db.Timestamptz(6)

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@map("payments")
}

// Webhook dedup ledger (platform-level, mirrors BillingEvent). A replayed gateway webhook collides on
// gatewayEventId @unique → P2002 → the transaction rolls back → no double-confirm / double-receipt.
model PaymentEvent {
  id             String   @id @default(cuid())
  gatewayEventId String   @unique
  type           String
  payload        Json?
  createdAt      DateTime @default(now()) @db.Timestamptz(6)

  @@map("payment_events")
}

// ─── Catalogs (global config-as-data) ────────────────────────────────────────
// Platform-level suggestions consumed by the consultant app (SP-2): theme colors, fonts,
// calendar providers. Super-admin managed, read by all consultants → global, NOT tenant-scoped.
// `value` holds type-specifics: {hex} for colors, {script, fontFamily} for fonts, {} for providers.

enum CatalogType {
  theme_color
  font
  calendar_provider
}

model CatalogItem {
  id        String      @id @default(cuid())
  type      CatalogType
  key       String
  label     String
  value     Json        @default("{}")
  isActive  Boolean     @default(true)
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt DateTime    @updatedAt @db.Timestamptz(6)

  @@unique([type, key])
  @@index([type, isActive])
  @@map("catalog_items")
}
